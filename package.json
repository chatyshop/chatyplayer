{
  "name": "chatyplayer",
  "version": "1.0.0",
  "description": "Lightweight, modular, secure HTML5 video player with modern features.",
  "type": "module",

  "main": "./dist/chatyplayer.cjs.js",
  "module": "./dist/chatyplayer.es.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chatyplayer.es.js",
      "require": "./dist/chatyplayer.cjs.js",
      "default": "./dist/chatyplayer.es.js"
    },
    "./styles/*": "./dist/styles/*"
  },

  "files": [
    "dist"
  ],

  "sideEffects": [
    "**/*.css"
  ],

  "keywords": [
    "video-player",
    "html5-video",
    "javascript-player",
    "typescript",
    "lightweight",
    "chatyplayer"
  ],

  "author": "ChatyDevOps",
  "license": "MIT",

  "homepage": "https://github.com/chatyshop/chaty_player",

  "repository": {
    "type": "git",
    "url": "https://github.com/chatyshop/chaty_player.git"
  },

  "bugs": {
    "url": "https://github.com/chatyshop/chaty_player/issues"
  },

  "engines": {
    "node": ">=18"
  },

  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepare": "npm run clean && npm run build"
  },

  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "rimraf": "^5.0.0"
  },

  "peerDependencies": {},

  "dependencies": {}
}